{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile containing basic info and saved preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "preferences": {
          "type": "object",
          "properties": {
            "vibe": { "type": "string", "enum": ["adventure", "relaxation", "culture", "foodie", "luxury"] },
            "budget": { "type": "string", "enum": ["low", "medium", "high"] },
            "pace": { "type": "string", "enum": ["slow", "moderate", "fast"] }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Trip": {
      "title": "Travel Itinerary",
      "description": "A generated trip itinerary with multiple days and stops.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "destination": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "vibe": { "type": "string" },
        "days": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "dayNumber": { "type": "integer" },
              "activities": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "time": { "type": "string" },
                    "placeName": { "type": "string" },
                    "placeId": { "type": "string" },
                    "description": { "type": "string" },
                    "lat": { "type": "number" },
                    "lng": { "type": "number" },
                    "category": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "destination", "days"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/trips/{tripId}": {
      "schema": "Trip",
      "description": "Travel itineraries"
    }
  }
}
